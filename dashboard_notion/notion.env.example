# dashboard_notion — copy to `notion.env` (same dir, or repo root / CWD) and fill in.
# Get both values from https://www.notion.so/my-integrations
#   1. Create an internal integration -> copy its "Internal Integration Secret".
#   2. Open the target Notion page -> ••• -> Connections -> add your integration
#      (REQUIRED, or the API returns 401/404).
#   3. Copy the page id from its URL (the 32-hex tail).

NOTION_API_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_DASHBOARD_PAGE_ID=00000000000000000000000000000000

# Optional overrides (else defaults next to the script are used):
# DASHBOARD_STATE=/path/to/dashboard_state.json
# DASHBOARD_HTML=/path/to/dashboard.html
